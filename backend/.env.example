# Supabase Configuration
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your-service-role-key-here
SUPABASE_ANON_KEY=your-anon-key-here

# Server Configuration
NODE_ENV=development
PORT=5000
JWT_SECRET=your-jwt-secret-key-change-in-production

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Email Configuration
# Primary: Brevo SMTP (Recommended for production)
# Get API key from: https://app.brevo.com/settings/keys/api
BREVO_API_KEY=your-brevo-api-key-here
BREVO_EMAIL_FROM=your-verified-email@example.com

# Backup: Gmail SMTP (may not work on some hosting platforms)
# To get Gmail App Password:
# 1. Go to https://myaccount.google.com/security
# 2. Enable 2-Step Verification
# 3. Go to https://myaccount.google.com/apppasswords
# 4. Generate app password for "Mail"
GMAIL_USER=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password-here

# SMS Configuration (Optional)
SMS_API_KEY=your_africas_talking_api_key
SMS_USERNAME=your_africas_talking_username
